{
  // 白名单，只有在白名单中的配方才会被显示，如果白名单为空，则所有配方都会被显示
  // 可以使用正则表达式，正则表达式请以^开头，$结尾
  // 比如 ^.*$ 表示所有配方
  // 这里的"^[\\w]+:gun/[\\w]+$"表示匹配所有命名空间的“枪”
  // （前提是枪包作者按照规范将枪的配方文件放置在了gun/路径下）
  // 常用例子：匹配命名空间xxx下的所有配方：^xxx:.*$
  "whitelist": [
    "^[\\w]+:gun/[\\w]+$"
  ],
  // 黑名单，在白名单中的配方中，如果在黑名单中，则不会被显示
  "blacklist": [
    "tacz:test"
  ]
}